# Environment
NODE_ENV=development
PORT=5000

# Backend API Base URL
VITE_API_BASE_URL=http://localhost:9000

# Agent SDK Base URL (for Claude Agent SDK integration)
VITE_AGENT_BASE_URL=http://localhost:3000

# Mock Data Mode (set to 'false' to use live API calls instead of mock data)
VITE_USE_MOCK_DATA=true

# Deployment Configuration (Optional - for production)
VITE_DEPLOYMENT_ID=
VITE_BUILDER_PLATFORM_LOGO=
VITE_BUILDER_PLATFORM_NAME=
VITE_BUILDER_PLATFORM_URL=
